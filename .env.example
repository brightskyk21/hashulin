# ── 네이버 지도 (지도 표시용) ──────────────────────────────────
# 네이버 클라우드 플랫폼(ncloud.com) > Maps > Application 등록 > Web Dynamic Map
# Client ID는 프론트에 노출돼도 되는 값 (도메인 제한으로 보호)
NAVER_MAP_CLIENT_ID=여기에_지도_Client_ID

# ── 네이버 검색 (가게 검색용) ──────────────────────────────────
# developers.naver.com > 애플리케이션 등록 > 검색 API 사용
NAVER_SEARCH_CLIENT_ID=여기에_검색_Client_ID
NAVER_SEARCH_CLIENT_SECRET=여기에_검색_Client_Secret

# ── Supabase (저장소) ──────────────────────────────────────────
# supabase.com > 프로젝트 > Settings > API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=여기에_service_role_key

# 로컬 실행 포트 (Render는 자동 주입하므로 비워둬도 됨)
PORT=3000
